{
  "name": "wagyr",
  "version": "1.0.0",
  "description": "Wagyr Legacies NFT smart contract system",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "test:solidity": "hardhat test solidity",
    "test:ts": "hardhat test nodejs",
    "deploy:local": "hardhat ignition deploy ignition/modules/WagyrLegacies.ts --network hardhatMainnet",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/WagyrLegacies.ts --network sepolia",
    "deploy:base-sepolia": "hardhat ignition deploy ignition/modules/WagyrLegacies.ts --network baseSepolia",
    "deploy:base": "hardhat --build-profile production ignition deploy ignition/modules/WagyrLegacies.ts --network base",
    "deploy:params:check": "tsx scripts/validate-deploy-params.ts",
    "deploy:params:check:base": "tsx scripts/validate-deploy-params.ts --file ignition/parameters/base.json --mainnet",
    "pin:ipfs": "tsx scripts/pin-ipfs.ts",
    "claim:generate": "tsx scripts/generate-claim.ts",
    "claim:mint": "tsx scripts/mint-claim.ts",
    "verify": "hardhat verify"
  },
  "keywords": [
    "wagyr",
    "nft",
    "erc721",
    "hardhat"
  ],
  "author": "olaoluwa057",
  "license": "ISC",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@types/node": "^26.0.1",
    "dotenv": "^17.4.2",
    "hardhat": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "viem": "^2.53.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
